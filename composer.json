{
    "name": "api-platform/installer",
    "description": "API Platform application installer.",
    "type": "library",
    "license": "MIT",
    "keywords": ["api-platform", "installer", "scaffold", "symfony", "laravel"],
    "require": {
        "php": "^8.3",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^7.2",
        "symfony/filesystem": "^7.2",
        "symfony/process": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "ApiPlatform\\Installer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ApiPlatform\\Installer\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/api-platform"],
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
